#include <stdio.h>
int main()
{
    int size;
    printf("size: ");
    scanf("%d", &size);

    if(size < 1 || size > 8){
        printf("Invalid size! must be between 1 and 8!");
        return 0;
    }

    for(int i = 0; i <= size; i++){
        for(int j = size; j > 0; j--){
            if(j > i){
                printf(" ");
            } else {
                printf("#");
            }
        }
        printf(" ");
        for(int j = 0; j < i; j++){
            printf("#");
        }
        printf("\n");
    }

}
