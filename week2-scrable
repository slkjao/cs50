#include <stdio.h>

int main()
{
    char input1[21], input2[21];
    int pontosPlayer1 = 0, pontosPlayer2 = 0;

    printf("Player 1: ");
    fgets(input1, sizeof(input1), stdin);
    printf("Player 2: ");
    fgets(input2, sizeof(input2), stdin);

    for(int i = 0; input1[i] != '\0'; i++)
    {
        input1[i] = toupper((unsigned char) input1[i]);
        if (input1[i] == 'A' || input1[i] == 'E' || input1[i] == 'I' || input1[i] == 'L' ||
                input1[i] == 'N' || input1[i] == 'O' || input1[i] == 'R' || input1[i] == 'S' ||
                input1[i] == 'T' || input1[i] == 'U')
        {
            pontosPlayer1 += 1;
        }
        else if (input1[i] == 'D' || input1[i] == 'G')
        {
            pontosPlayer1 += 2;
        }
        else if (input1[i] ==  'B' || input1[i] == 'C' || input1[i] == 'M'|| input1[i] == 'P')
        {
            pontosPlayer1 += 3;
        }
        else if (input1[i] ==  'F' || input1[i] ==  'H' || input1[i] ==  'V' || input1[i] ==  'W' || input1[i] ==  'Y')
        {
            pontosPlayer1 += 4;
        }
        else if (input1[i] ==  'K')
        {
            pontosPlayer1 += 5;
        }
        else if (input1[i] == 'J' || input1[i] == 'X')
        {
            pontosPlayer1 += 8;
        }
        else if (input1[i] == 'Q' || input1[i] == 'Z')
        {
            pontosPlayer1 += 10;
        }
    }

    for(int i = 0; input2[i] != '\0'; i++)
    {
        input2[i] = toupper((unsigned char) input2[i]);
        if (input2[i] == 'A' || input2[i] == 'E' || input2[i] == 'I' || input2[i] == 'L' ||
                input2[i] == 'N' || input2[i] == 'O' || input2[i] == 'R' || input2[i] == 'S' ||
                input2[i] == 'T' || input2[i] == 'U')
        {
            pontosPlayer2 += 1;
        }
        else if (input2[i] == 'D' || input2[i] == 'G')
        {
            pontosPlayer2 += 2;
        }
        else if (input2[i] ==  'B' || input2[i] == 'C' || input2[i] == 'M'|| input2[i] == 'P')
        {
            pontosPlayer2 += 3;
        }
        else if (input2[i] ==  'F' || input2[i] ==  'H' || input2[i] ==  'V' || input2[i] ==  'W' || input2[i] ==  'Y')
        {
            pontosPlayer2 += 4;
        }
        else if (input2[i] ==  'K')
        {
            pontosPlayer2 += 5;
        }
        else if (input2[i] == 'J' || input2[i] == 'X')
        {
            pontosPlayer2 += 8;
        }
        else if (input2[i] == 'Q' || input2[i] == 'Z')
        {
            pontosPlayer2 += 10;
        }
    }

    if(pontosPlayer1 > pontosPlayer2){
        printf("Player 1 wins!");
    } else if (pontosPlayer2 > pontosPlayer1){
        printf("Player 2 wins!");
    } else {
        printf("Tie!");
    }



    return 0;
}
